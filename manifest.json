{
    "manifest_version": 3,
    "name": "Patient Mapper",
    "version": "2.9",
    "description": "Maps hospital patients.",
    "permissions": ["tabs", "scripting", "activeTab", "storage"],
    "host_permissions": [
        "https://api.rsudsoediranms.com/*",
        "https://*.rsudsoediranms.com/*"
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
